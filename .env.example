# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL on Render/VPS:
DATABASE_URL=

# SQLite fallback (used when DATABASE_URL is empty):
DB_PATH=blocker.db

# ── Admin API ─────────────────────────────────────────────────────────────────
ADMIN_TOKEN=change-me-to-a-strong-random-secret

# Hours to wait before an unlock request takes effect (self-blocking delay)
UNLOCK_DELAY_HOURS=48

# ── DNS Server ────────────────────────────────────────────────────────────────
UPSTREAM_DNS=1.1.1.1
DNS_PORT=53

# Set to "false" to disable query logging (reduces DB writes)
LOG_QUERIES=true

# How often (seconds) the DNS server reloads the blocklist from DB
RELOAD_INTERVAL=300
